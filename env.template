# Public variables exposed to the browser (safe to expose)
# Required for the Next.js app and browser-side Supabase / Edge Function calls
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key

# Recommended site URL for SEO / canonical links
NEXT_PUBLIC_SITE_URL=https://macmaa.org.au

# Optional API base override. Keep the default unless you proxy /api elsewhere.
# NEXT_PUBLIC_ADMIN_API_BASE=/api

# Development-only toggle. Never enable in preview / production.
# NEXT_PUBLIC_ENABLE_MOCK_ADMIN_ACCOUNTS=false

# Server-side only secrets (Next.js API Routes / Vercel server runtime)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
JWT_SECRET=replace-with-a-long-random-secret

# Stripe payment gateway (required only if online card payment is enabled)
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
# STRIPE_PAYMENT_CURRENCY=aud  # Optional, defaults to "aud"

# Resend email service (recommended for notifications)
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL="MACMAA <onboarding@resend.dev>"
ADMIN_NOTIFICATION_EMAIL=admin@macmaa.org

# Optional test recipient used by email-related checks
TEST_EMAIL=your-test-email@example.com

# Optional initial admin account bootstrap
# Used only when admin_accounts table is empty
INITIAL_ADMIN_USERNAME=owner_admin
INITIAL_ADMIN_EMAIL=owner@macmaa.org
INITIAL_ADMIN_PASSWORD=your-strong-password-here

# Optional: local Supabase Edge Function debugging only.
# In production these should be configured as Supabase Edge Function Secrets.
UNSPLASH_ACCESS_KEY=your-unsplash-access-key

# Optional CLI / CI variables (not used by application runtime)
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_ACCESS_TOKEN=your-supabase-access-token

# Legacy aliases still recognized by parts of the codebase for compatibility:
# VITE_SUPABASE_URL
# VITE_SUPABASE_ANON_KEY
# VITE_ADMIN_API_BASE
# VITE_ENABLE_MOCK_ADMIN_ACCOUNTS
# VITE_SUPABASE_SERVICE_ROLE_KEY
# ADMIN_EMAIL
# CONTACT_EMAIL
# Do not add new deployments with these names; use the standard variables above.
